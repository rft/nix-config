{
  // environment (PATH, LD_LIBRARY_PATH for mesa/libGL, etc.) is available
  // to the integrated terminal, debugger, and Python extension.
  "direnv.restart.automatic": true,

  // (not the /nix/store/... path) so it survives devenv rebuilds.
  "python.defaultInterpreterPath": "${workspaceFolder}/.devenv/state/venv/bin/python",
  "python.terminal.activateEnvInCurrentTerminal": true
}
