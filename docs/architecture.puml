@startuml nix-config-architecture
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName "Fira Code"
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam nodesep 15
skinparam ranksep 25
skinparam padding 3

title rft's NixOS Flake Architecture
header denix-based modular NixOS + Darwin + Home Manager configuration

' ═══════════════════════════════════════════════════
' FLAKE — the entry point
' ═══════════════════════════════════════════════════

package "flake.nix" as flake #BBDEFB {
  component "denix.lib.configurations" as engine
  note bottom of engine
    scans **paths**: ./hosts + ./modules
    host types: desktop | server | wsl | installer | darwin
    homeManagerUser: "nano"
  end note
}

' ═══════════════════════════════════════════════════
' HOSTS — delib.host declarations
' Each host sets name, type, system, and myconfig
' enable flags that activate modules
' ═══════════════════════════════════════════════════

package "hosts/ — delib.host" as hosts #C8E6C9 {

  note as hostTable
    |= Host |= Type |= System |
    | bristlecone | server | x86_64-linux |
    | cottonwood | desktop | x86_64-linux |
    | redwood | desktop | x86_64-linux |
    | sequoia | desktop | x86_64-linux |
    | myrtle | desktop | x86_64-linux |
    | mistletoe | wsl | x86_64-linux |
    | lemon | darwin | aarch64-darwin |
    | pineapple | darwin | aarch64-darwin |
    | installer | installer | x86_64-linux |
  end note

  note as hostExample
    **delib.host** example:
    ....
    name = "mistletoe";
    type = "wsl";
    system = "x86_64-linux";
    myconfig = {
      programs.programming.enable = true;
      programs.programming.cloud.enable = true;
    };
    ....
  end note
}

engine --> hosts : discovers

' ═══════════════════════════════════════════════════
' OUTPUTS — what denix produces
' ═══════════════════════════════════════════════════

component "nixosConfigurations" as nixOut #BBDEFB
component "darwinConfigurations" as darwinOut #BBDEFB
component "homeConfigurations" as homeOut #BBDEFB

engine -down-> nixOut : builds
engine -down-> darwinOut : builds
engine -down-> homeOut : builds

nixOut -[hidden]right- darwinOut
darwinOut -[hidden]right- homeOut

' ═══════════════════════════════════════════════════
' MODULES — delib.module declarations
' Each module has enable option + platform blocks
' ═══════════════════════════════════════════════════

rectangle "modules/ — delib.module" as mods #FFE0B2 {

  note as modPattern
    **delib.module** pattern:
    ....
    name = "desktop.niri";
    options = delib.singleEnableOption false;

    myconfig.always — auto-enable from parent
    nixos.ifEnabled — NixOS-only config
    darwin.ifEnabled — macOS-only config
    home.ifEnabled — both platforms (HM)
    ....
  end note

  note as enableTable
    **Module enablement by host**
    |= Module |= bristlecone |= cottonwood |= redwood |= sequoia |= myrtle |= mistletoe |= lemon |= pineapple |
    | config, core | all | all | all | all | all | all | all | all |
    | terminal, editors | all | all | all | all | all | all | all | all |
    | desktop |  -  | Y | Y | Y | Y |  -  |  -  |  -  |
    | desktop.paneru |  -  |  -  |  -  |  -  |  -  |  -  | Y |  -  |
    | applications |  -  | Y | Y | Y | Y |  -  | Y | Y |
    | programming |  -  | Y | Y | Y |  -  | Y | Y | Y |
    | services | Y |  -  |  -  |  -  |  -  |  -  |  -  |  -  |
    | security | Y |  -  |  -  |  -  |  -  |  -  |  -  |  -  |
  end note

  package "config //(always on)//" as cfgMod {
    component "constants, user\nhome, overlays, darwin" as cfgAll
  }

  package "core //(always on)//" as coreMod {
    component "~60 CLI packages\npodman, GC, ssh\nxonsh (system)" as coreAll
  }

  package "terminal" as termMod {
    component "bash, zsh, atuin, zoxide\nkitty, starship, nushell\nxonsh (home), zellij" as termAll
  }

  package "editors" as edMod {
    component "VSCodium (30+ ext)\nhelix, doom-emacs" as edAll
  }

  package "desktop" as deskMod {
    component "noctalia, niri\nawesome, rofi\ngreetd, paneru" as deskAll
  }

  package "applications" as appMod {
    component "base, creative\nengineering, archiving\nfloorp, kando, kdenlive" as appAll
  }

  package "programming" as progMod {
    component "nixd, nodejs, python\ncloud, analysis" as progAll
  }

  package "services" as svcMod {
    component "jellyfin, ollama\nhome-assistant, n8n\npaperless, kasm\nchangedetection\nborgmatic" as svcAll
  }

  package "security" as secMod {
    component "nix-mineral" as secAll
  }

  package "fonts" as fontMod {
    component "FiraCode, Inter\nJetBrains Mono" as fontAll
  }
}

hosts ..> mods : myconfig.*.enable\nactivates modules

' ═══════════════════════════════════════════════════
' PLATFORM ROUTING — how module blocks become output
' ═══════════════════════════════════════════════════

mods -down-> nixOut : nixos.* blocks
mods -down-> darwinOut : darwin.* blocks
mods -down-> homeOut : home.* blocks

' ═══════════════════════════════════════════════════
' SUPPORT LAYERS
' ═══════════════════════════════════════════════════

package "lib/" as libPkg #F3E5F5 {
  component "python-core-packages\nxonsh-extra-packages" as libAll
}

package "packages/" as pkgPkg #FCE4EC {
  component "xxh, rofi-desktop\ninstaller-iso" as pkgAll
}

package "config/" as cfgPkg #E0F7FA {
  component "awesome/, niri/\nkando/" as cfgDots
}

libPkg -up-> mods : imported by\nmodules
pkgPkg -up-> mods : installed by\nmodules
cfgPkg -up-> mods : symlinked by\nmodules

' ═══════════════════════════════════════════════════
' LAYOUT CONTROL
' ═══════════════════════════════════════════════════

' Module grid
cfgMod -[hidden]right- coreMod
coreMod -[hidden]right- termMod
termMod -[hidden]right- edMod
edMod -[hidden]right- deskMod

appMod -[hidden]right- progMod
progMod -[hidden]right- svcMod
svcMod -[hidden]right- secMod
secMod -[hidden]right- fontMod

cfgMod -[hidden]down- appMod
coreMod -[hidden]down- progMod
termMod -[hidden]down- svcMod
edMod -[hidden]down- secMod
deskMod -[hidden]down- fontMod

' Support layer
libPkg -[hidden]right- pkgPkg
pkgPkg -[hidden]right- cfgPkg

' ═══════════════════════════════════════════════════
' LEGEND
' ═══════════════════════════════════════════════════

legend bottom right
  |= Color |= Layer |
  |<#BBDEFB> | Flake Engine + Outputs |
  |<#C8E6C9> | Host Declarations |
  |<#FFE0B2> | Module Definitions |
  |<#F3E5F5> | Shared Libraries |
  |<#FCE4EC> | Custom Packages |
  |<#E0F7FA> | Dotfile Configs |
endlegend

@enduml
